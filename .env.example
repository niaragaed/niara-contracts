# Copie para .env e preencha localmente. NUNCA commitar .env nem chaves privadas reais.
# .env já está no .gitignore — confirme com `git status` antes de qualquer commit.
# Use SEMPRE uma carteira descartável, criada só para testnet, sem nenhum valor real.
# Deploy nesta etapa é restrito a testnet (Sepolia) — nunca mainnet, sem pedido explícito.

# RPC de uma rede de teste (ex.: Sepolia). Não usar mainnet nesta etapa.
RPC_URL=

# Chave privada de uma conta de TESTE, sem fundos reais. Nunca a chave de uma conta real.
PRIVATE_KEY=

# Chave de API para verificação de contrato em block explorer (ex.: Etherscan).
ETHERSCAN_API_KEY=

# ── Papéis do deploy (script/Deploy.s.sol) ──────────────────────────────────────────
# Todos opcionais — se vazios, o próprio endereço de PRIVATE_KEY assume todos os papéis
# (deployer = admin = operator = custodian = issuer), o que é suficiente para rodar o
# script/Demo.s.sol sem precisar de mais nenhuma chave privada.

# Titular de DEFAULT_ADMIN_ROLE/PAUSER_ROLE nos quatro contratos (recomendado: multisig
# em produção; carteira descartável é suficiente em testnet).
ADMIN_ADDRESS=

# Titular de OPERATOR_ROLE (BackingGateway) e SETTLEMENT_OPERATOR_ROLE (NiaraSettlement).
OPERATOR_ADDRESS=

# Titular de CUSTODIAN_ROLE (BackingGateway).
CUSTODIAN_ADDRESS=

# Carteira do emissor do AssetToken de demonstração (recebe o cashback). Se for diferente
# de PRIVATE_KEY, o passo de `withdraw` do script/Demo.s.sol não vai funcionar — este
# script só assina transações com a chave do deployer.
ISSUER_WALLET_ADDRESS=

# Atraso do timelock em segundos para os contratos implantados. Mínimo permitido pelo
# contrato: 3600 (1 hora) — não há como reduzir, nem em testnet.
TIMELOCK_DELAY=3600

# ── Metadados do AssetToken de demonstração (script/Deploy.s.sol) ──────────────────
ASSET_NAME=Niara Demo Equity
ASSET_SYMBOL=nDEMO
ASSET_REFERENCE=DEMO
ASSET_COUNTRY=US

# ── Parâmetros do fluxo de demonstração (script/Demo.s.sol) ────────────────────────
DEMO_BACKING_QUANTITY=1000000000000000000000
DEMO_SETTLE_ASSET_AMOUNT=100000000000000000000
DEMO_SETTLE_PAYMENT_AMOUNT=10000000000
DEMO_BUYER_GAS_FUNDING_WEI=10000000000000000

# ── Preenchidas pela FASE 1 do deploy (copie a saída de `forge script Deploy.s.sol`) ─
# Necessárias para script/Deploy.s.sol --sig "executeWiring()" (fase 2) e para
# script/Demo.s.sol.
DEPLOYED_USDT_ADDRESS=
DEPLOYED_WBTC_ADDRESS=
DEPLOYED_DISTRIBUTOR_ADDRESS=
DEPLOYED_SETTLEMENT_ADDRESS=
DEPLOYED_GATEWAY_ADDRESS=
DEPLOYED_ASSET_TOKEN_ADDRESS=
