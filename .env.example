# Copie para .env e preencha localmente. NUNCA commitar .env nem chaves privadas reais.
# Nesta etapa do projeto não há deploy em nenhuma rede — estas variáveis são para uso futuro.

# RPC de uma rede de teste (ex.: Sepolia). Não usar mainnet nesta etapa.
RPC_URL=

# Chave privada de uma conta de TESTE, sem fundos reais. Nunca a chave de uma conta real.
PRIVATE_KEY=

# Chave de API para verificação de contrato em block explorer (ex.: Etherscan).
ETHERSCAN_API_KEY=
